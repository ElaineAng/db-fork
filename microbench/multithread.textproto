# Example benchmark task configuration
# This configuration runs a Nth operation benchmark measuring READ cost
# after creating 5 spine branches with 100 inserts each.

run_id: "dolt_tpcc_multithread_100_fanout"
backend: DOLT

# Table to benchmark (empty means random table from schema)
table_name: "orders"

# Starting branch (empty means default/main branch)
starting_branch: ""

database_setup {
  db_name: "microbench"
  cleanup: true
  
  # Create from SQL dump
  sql_dump {
    sql_dump_path: "db_setup/ch_benchmark_schema.sql"
  }
}

# Range update configuration (used when operation is RANGE_UPDATE)
range_update_config {
  range_size: 20
}

autocommit: true

num_threads: 100

# Benchmark mode (choose one):

# Option 1: Randomized average-cost benchmark mode
# randomized_benchmark {
#   operations: READ
#   operations: INSERT
#   operations: BRANCH
#   operations: RANGE_UPDATE
#   num_ops: 1000
# }

# Option 2: Nth operation benchmark mode
# Creates setup state (branches + data) then measures the operation num_ops times.
nth_op_benchmark {
  operation: BRANCH
  num_ops: 1
  setup {
    num_branches: 0
    branch_shape: FAN_OUT
    inserts_per_branch: 1000
  }
}

