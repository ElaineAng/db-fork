# Software Development workflow — Neon backend
# Neon limit: 20 branches. Reduced to fit within branch limit.

run_id: "macro_software_dev_neon"
backend: NEON
workflow: SOFTWARE_DEV

database_setup {
    db_name: "macrobench_softdev"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/ch_benchmark_schema.sql"
    }
}

setup {
    workers: 3              # T (reduced from 5)
    total_steps: 6          # S (reduced; 3*6=18 + main = 19 branches)
    root_fanout: 5          # F_r
    inner_fanout: 3         # F_i
    max_depth: 3            # D
    cross_branch_queries: 1 # C
}

step {
    schema_changes: 1   # M_s
    data_mutations: 1   # M_d
    eval_queries: 2     # Q_v
    prune_prob: 0.1     # gamma
}

autocommit: true
