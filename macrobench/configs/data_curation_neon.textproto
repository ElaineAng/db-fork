# Data Curation workflow — Neon backend
# Flat star, increased pruning to stay under 20 branches.

run_id: "macro_data_curation_neon"
backend: NEON
workflow: DATA_CURATION

database_setup {
    db_name: "macrobench_datacur"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/tpcc_schema.sql"
    }
}

setup {
    workers: 5       # T
    total_steps: 18  # S (reduced from 25)
    db_size: 100     # W
    max_fanout: 18   # F
    max_depth: 1     # D (forces flat star)
}

step {
    mutations: 5     # M
    ddl_count: 1     # M_DDL
    queries: 20      # Q
    merge_prob: 0.2  # mu
}

background {
    interval: 5      # B
    prune_fraction: 0.4 # gamma (increased from 0.3)
}

autocommit: true
