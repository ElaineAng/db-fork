# Data Cleaning workflow (Table 1, Section 3.3)
# Multiple cleaning strategies on overlapping regions.
# Tree shape: moderate depth (F_r=10, F_i=3, D=3).

run_id: "macro_data_cleaning"
backend: DOLT
workflow: DATA_CLEANING

database_setup {
    db_name: "macrobench_dataclean"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/ch_benchmark_seed.sql"
    }
}

setup {
    workers: 10             # T
    total_steps: 20         # S (per worker)
    root_fanout: 10         # F_r
    inner_fanout: 3         # F_i
    max_depth: 3            # D
    cross_branch_queries: 2 # C
    db_scale: 0             # 1 warehouses, 1K items, 100 cust/district
}

step {
    schema_changes: 1   # M_s
    data_mutations: 1   # M_d
    eval_queries: 1     # Q_v
    prune_prob: 0.0     # gamma (no pruning)
}

autocommit: true
