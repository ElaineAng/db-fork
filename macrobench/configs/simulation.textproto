# Simulation workflow (Table 1, Section 3.3)
# Sequential DML per time step, batch fork from single parent.
# Tree shape: flat star (D=1, F=50).

run_id: "macro_simulation"
backend: DOLT
workflow: SIMULATION

database_setup {
    db_name: "macrobench_sim"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/tpcc_schema.sql"
    }
}

setup {
    workers: 20      # T
    total_steps: 50  # S
    db_size: 100     # W
    max_fanout: 50   # F
    max_depth: 1     # D (forces flat star)
}

step {
    mutations: 50    # M
    ddl_count: 0     # M_DDL
    queries: 5       # Q
    merge_prob: 0    # mu
}

background {
    interval: 50     # B
    prune_fraction: 1.0 # gamma (discard all after aggregation)
}

autocommit: true
