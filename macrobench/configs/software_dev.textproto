# Software Development workflow (Table 1, Section 3.3)
# DDL-heavy: schema migrations, seed data, integrity tests.
# Tree shape: moderate depth chain (F=3, D=10).

run_id: "macro_software_dev"
backend: DOLT
workflow: SOFTWARE_DEV

database_setup {
    db_name: "macrobench_softdev"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/tpcc_schema.sql"
    }
}

setup {
    workers: 2       # T
    total_steps: 20  # S
    db_size: 10      # W (warehouse scale factor)
    max_fanout: 3    # F
    max_depth: 10    # D
}

step {
    mutations: 5     # M
    ddl_count: 3     # M_DDL
    queries: 5       # Q
    merge_prob: 0.1  # mu
}

background {
    interval: 20     # B
    prune_fraction: 0 # gamma
}

autocommit: true
