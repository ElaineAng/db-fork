# What-if Analysis (MCTS) workflow (Table 1, Section 3.3)
# Lightweight DML + analytical reward queries.
# Tree shape: deep bounded tree (F=5, D=25).

run_id: "macro_what_if"
backend: DOLT
workflow: WHAT_IF

database_setup {
    db_name: "macrobench_whatif"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/tpcc_schema.sql"
    }
}

setup {
    workers: 10      # T
    total_steps: 500 # S
    db_size: 100     # W
    max_fanout: 5    # F
    max_depth: 25    # D
}

step {
    mutations: 1     # M
    ddl_count: 0     # M_DDL
    queries: 1       # Q
    merge_prob: 0    # mu
}

background {
    interval: 50     # B
    prune_fraction: 0.1 # gamma
}

autocommit: true
