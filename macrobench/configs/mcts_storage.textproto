# MCTS workflow — storage amplification test.
# Same as mini config but with no pruning (prune_prob: 0.0).

run_id: "storage_mcts"
backend: NEON
workflow: MCTS

database_setup {
    db_name: "storage_mcts"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/ch_benchmark_seed.sql"
    }
}

setup {
    workers: 3              # T  (matches mini)
    total_steps: 8          # S  (matches mini)
    root_fanout: 5          # F_r (matches mini)
    inner_fanout: 3         # F_i (matches mini)
    max_depth: 5            # D  (matches mini)
    cross_branch_queries: 0 # C (matches mini)
    db_scale: 1
}

step {
    schema_changes: 0   # M_s
    data_mutations: 1   # M_d
    eval_queries: 0     # Q_v (skip reads - storage test)
    prune_prob: 0.0     # gamma (no deletion - storage test)
}

autocommit: true
measure_storage: true
