run_id: "isolation_neon"
backend: NEON
autocommit: true

database_setup {
    db_name: "isolation_bench"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/ch_benchmark_schema.sql"
    }
}

# Phase A: branch-count scaling (max 20 branches on Neon)
branch_counts: [0, 5, 10, 15]
queries_per_step: 3
mutations_per_branch: 5

# Phase B: OLTP/OLAP interference
olap_thread_counts: [1, 2, 4]
interference_duration_sec: 60
warmup_sec: 5
