run_id: "isolation_neon"
backend: NEON
autocommit: true

database_setup {
    db_name: "isolation_bench"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/ch_benchmark_seed.sql"
    }
}

# Phase A: branch-count scaling (lower counts to avoid Neon rate limits)
branch_counts: [0, 5, 10, 16]
queries_per_step: 3
mutations_per_branch: 5

# Phase B: OLTP/OLAP interference
olap_thread_counts: [2, 8, 16]
interference_duration_sec: 60
warmup_sec: 5
