# Failure Reproduction workflow — storage amplification test.
# Same as mini config but with no pruning (prune_prob: 0.0).

run_id: "storage_failure_repro"
backend: NEON
workflow: FAILURE_REPRO

database_setup {
    db_name: "storage_failrepro"
    cleanup: true
    sql_dump {
        sql_dump_path: "db_setup/ch_benchmark_seed.sql"
    }
}

setup {
    workers: 1              # T  (matches mini)
    total_steps: 10         # S  (matches mini)
    root_fanout: 10         # F_r (matches mini)
    max_depth: 1            # D
    cross_branch_queries: 0 # C (matches mini)
    db_scale: 1
}

step {
    schema_changes: 5   # M_s
    data_mutations: 45  # M_d
    eval_queries: 0     # Q_v (skip reads - storage test)
    prune_prob: 0.0     # gamma (no deletion - storage test)
}

autocommit: true
measure_storage: true
